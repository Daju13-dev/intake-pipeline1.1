{
  "version": 2,
  "builds": [
    { "src": "api/face_check.py", "use": "@vercel/python" },
    { "src": "api/chat.py", "use": "@vercel/python" },
    { "src": "api/reps.py", "use": "@vercel/python" },
    { "src": "api/support.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "face-check/**", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.MOV", "use": "@vercel/static" },
    { "src": "*.mp4", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/pitchcardex\\.html$", "status": 308, "headers": { "Location": "/index.html" } },
    { "src": "/api/face-check", "dest": "/api/face_check.py" },
    { "src": "/api/chat", "dest": "/api/chat.py" },
    { "src": "/api/reps/(.*)", "dest": "/api/reps.py" },
    { "src": "/api/reps", "dest": "/api/reps.py" },
    { "src": "/api/support/(.*)", "dest": "/api/support.py" },
    { "src": "/api/support", "dest": "/api/support.py" },
    { "handle": "filesystem" }
  ]
}
